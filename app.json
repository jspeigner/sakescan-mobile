{
  "expo": {
    "name": "SakeScan",
    "slug": "sakescan",
    "scheme": "sakescan",
    "version": "2.1.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sakescan",
      "infoPlist": {
        "NSCameraUsageDescription": "SakeScan uses the camera to capture photos inside the app before you publish them.",
        "NSMicrophoneUsageDescription": "SakeScan uses the microphone to record audio clips that stay with your in-app creations.",
        "NSPhotoLibraryUsageDescription": "SakeScan accesses your photo library to let you choose media that appears in the app.",
        "NSLocationWhenInUseUsageDescription": "SakeScan uses your location to show nearby stores that carry sake.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "2"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.sakescan",
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#FAFAF8"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-asset",
      "expo-localization",
      "expo-video",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "splash": {
      "image": "./icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "icon": "./icon.png",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7d2ac52c-8667-420b-beb1-3e6a6c0a5704"
      }
    }
  }
}
